{
  "name": "wc-prediction-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:scoring": "vitest run src/lib/scoring.test.ts",
    "seed:fixtures": "node scripts/generate-fixtures.mjs && node scripts/seed-fixtures.mjs",
    "sync:schedule": "node scripts/generate-fixtures.mjs && node scripts/generate-full-db-sync.mjs",
    "sync:scores": "py -3 scripts/score-sync/sync_scores.py",
    "sync:scores:dry": "py -3 scripts/score-sync/sync_scores.py --dry-run",
    "generate:match-cron": "node scripts/generate-match-sync-schedule.mjs > scripts/match-sync-schedule.sql",
    "verify:schedule": "node scripts/verify-et-schedule.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "canvas-confetti": "^1.9.3",
    "framer-motion": "^11.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.26.1",
    "vite": "^5.4.14",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^4.1.8",
    "workbox-window": "^7.3.0"
  }
}
