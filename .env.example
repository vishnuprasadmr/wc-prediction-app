VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_LEAGUE_INVITE_CODE=SIMELABS-WC26
# Production URL — set on Netlify/Vercel (fixes Google OAuth redirecting to localhost)
# VITE_APP_URL=https://your-app.netlify.app
# Optional: restrict Google sign-in to one email domain (leave unset to allow any Google account)
# VITE_ALLOWED_EMAIL_DOMAIN=simelabs.com
# Optional: Google Workspace hosted domain hint (only used when domain restriction is enabled)
# VITE_GOOGLE_HD=simelabs.com

# Server-side only (score sync script / GitHub Actions — never expose in frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
